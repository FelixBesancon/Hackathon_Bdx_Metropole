generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model HeatZone {
  id          Int      @id @default(autoincrement())
  name        String
  geometry    Json     // GeoJSON polygon
  temperature Float    // Température moyenne °C
  intensity   Int      // 1-5 niveau de chaleur
  createdAt   DateTime @default(now())
}

model CitizenAction {
  id        Int        @id @default(autoincrement())
  type      ActionType
  lat       Float
  lng       Float
  radius    Float      // Rayon d'impact en mètres
  impact    Float      // Réduction thermique estimée °C
  createdAt DateTime   @default(now())
}

enum ActionType {
  VEGETATION
  WATER_POINT
  SHADE
}
